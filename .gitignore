# Terraform state — contains sensitive AWS resource details
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Terraform workspace state directories
terraform.tfstate.d/

# Terraform variables — contains your IP address (auto-written by setup.py)
terraform.tfvars

# Terraform working directory
.terraform/

# Lock file is safe to commit (reproducible provider versions)
# .terraform.lock.hcl  ← intentionally NOT ignored

# Helm-generated values dump (may contain tokens if Observe token is in values)
observe-agent-values.yaml

# Secrets and environment config — DO NOT COMMIT
config.env
